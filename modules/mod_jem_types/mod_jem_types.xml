<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>JEM - Types Module</name>
    <author>JEM Community</author>
    <creationDate>May 2026</creationDate>
    <copyright>copyright (C) 2013-2026 joomlaeventmanager.net</copyright>
    <license>https://www.gnu.org/licenses/gpl-3.0 GNU/GPL</license>
    <authorEmail>info@joomlaeventmanager.net</authorEmail>
    <authorUrl>https://www.joomlaeventmanager.net</authorUrl>
    <version>5.0.0beta1</version>
    <description>MOD_JEM_TYPES_XML_DESCRIPTION</description>

    <scriptfile>script.php</scriptfile>

    <files>
        <filename module="mod_jem_types">mod_jem_types.php</filename>
        <filename>helper.php</filename>
        <filename>script.php</filename>
        <filename>index.html</filename>

        <folder>tmpl</folder>
        <folder>language</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/mod_jem_types.ini</language>
        <language tag="en-GB">language/en-GB/mod_jem_types.sys.ini</language>
    </languages>
    <help key="Modules" />
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="display_mode" type="list"
                    label="MOD_JEM_TYPES_DISPLAY_MODE"
                    description="MOD_JEM_TYPES_DISPLAY_MODE_DESC"
                    default="summary"
                    class="form-select w-auto"
                >
                    <option value="summary">MOD_JEM_TYPES_MODE_SUMMARY</option>
                    <option value="topn">MOD_JEM_TYPES_MODE_TOPN</option>
                </field>

                <field name="top_n" type="number"
                    label="MOD_JEM_TYPES_TOP_N"
                    description="MOD_JEM_TYPES_TOP_N_DESC"
                    default="3"
                    min="1"
                    max="20"
                    class="form-control w-auto"
                    showon="display_mode:topn"
                />

                <field name="show_more_information" type="list"
                    label="MOD_JEM_TYPES_SHOW_MORE_INFORMATION"
                    description="MOD_JEM_TYPES_SHOW_MORE_INFORMATION_DESC"
                    default="1"
                    class="form-select w-auto"
                    showon="display_mode:topn"
                >
                    <option value="1">MOD_JEM_TYPES_MORE_INFORMATION_LINK</option>
                    <option value="2">MOD_JEM_TYPES_MORE_INFORMATION_BUTTON</option>
                    <option value="0">JNO</option>
                </field>

                <field name="show_more_information_title" type="radio"
                    label="MOD_JEM_TYPES_SHOW_MORE_INFORMATION_TITLE"
                    description="MOD_JEM_TYPES_SHOW_MORE_INFORMATION_TITLE_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                    showon="display_mode:topn[AND]show_more_information:1,2,link,button"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="hide_empty" type="radio"
                    label="MOD_JEM_TYPES_HIDE_EMPTY"
                    description="MOD_JEM_TYPES_HIDE_EMPTY_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="show_when_empty" type="radio"
                    label="MOD_JEM_TYPES_SHOW_WHEN_EMPTY"
                    description="MOD_JEM_TYPES_SHOW_WHEN_EMPTY_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>

            <fieldset name="advanced">
                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_LAYOUT_DESC"
                    class="form-select w-auto"
                    validate="moduleLayout"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                    rows="3"
                    filter="string"
                />
                <field
                    name="cache"
                    type="list"
                    label="COM_MODULES_FIELD_CACHING_LABEL"
                    description="COM_MODULES_FIELD_CACHING_DESC"
                    default="1"
                    filter="integer"
                    class="form-select w-auto"
                >
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
                </field>
                <field
                    name="cache_time"
                    type="number"
                    label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
                    description="COM_MODULES_FIELD_CACHE_TIME_DESC"
                    default="900"
                    filter="integer"
                    class="form-control w-auto"
                />
            </fieldset>
        </fields>
    </config>
</extension>
