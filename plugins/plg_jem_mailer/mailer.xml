<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="jem" method="upgrade">
    <name>plg_jem_mailer</name>
    <author>JEM Community</author>
    <creationDate>4 July 2026</creationDate>
    <copyright>copyright (C) 2013-2026 joomlaeventmanager.net</copyright>
    <license>https://www.gnu.org/licenses/gpl-3.0 GNU/GPL</license>
    <authorEmail>info@joomlaeventmanager.net</authorEmail>
    <authorUrl>https://www.joomlaeventmanager.net</authorUrl>
    <version>5.1.0-alpha1</version>
    <description>PLG_JEM_MAILER_XML_DESCRIPTION</description>

    <files>
        <filename plugin="mailer">mailer.php</filename>
        <filename>index.html</filename>
        <folder>fields</folder>
        <folder>language</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/plg_jem_mailer.ini</language>
        <language tag="en-GB">language/en-GB/plg_jem_mailer.sys.ini</language>
    </languages>

    <config>
        <fields name="params" addfieldpath="/plugins/jem/mailer/fields">
            <fieldset name="profiles_matrix" label="PLG_JEM_MAILER_NOTIFICATIONS">
                <field type="mailerprofiles" name="mailer_profiles"
                    label="PLG_JEM_MAILER_PROFILES_MATRIX"
                    description="PLG_JEM_MAILER_PROFILES_MATRIX_DESC"
                />
                <field type="hidden" name="reg_mail_user" default="1" />
                <field type="hidden" name="reg_mail_creator" default="0" />
                <field type="hidden" name="reg_mail_admin" default="1" />
                <field type="hidden" name="reg_mail_category" default="0" />
                <field type="hidden" name="reg_mail_group" default="0" />
                <field type="hidden" name="reg_mail_user_onoff" default="1" />
                <field type="hidden" name="reg_mail_creator_onoff" default="0" />
                <field type="hidden" name="reg_mail_admin_onoff" default="1" />
                <field type="hidden" name="reg_mail_category_onoff" default="0" />
                <field type="hidden" name="reg_mail_group_onoff" default="0" />
                <field type="hidden" name="unreg_mail_user" default="1" />
                <field type="hidden" name="unreg_mail_creator" default="0" />
                <field type="hidden" name="unreg_mail_admin" default="1" />
                <field type="hidden" name="unreg_mail_category" default="0" />
                <field type="hidden" name="unreg_mail_group" default="0" />
                <field type="hidden" name="newevent_mail_user" default="1" />
                <field type="hidden" name="newevent_mail_admin" default="1" />
                <field type="hidden" name="newevent_mail_category" default="0" />
                <field type="hidden" name="newevent_mail_category_acl" default="0" />
                <field type="hidden" name="newevent_mail_group" default="0" />
                <field type="hidden" name="editevent_mail_user" default="1" />
                <field type="hidden" name="editevent_mail_creator" default="0" />
                <field type="hidden" name="editevent_mail_admin" default="1" />
                <field type="hidden" name="editevent_mail_registered" default="0" />
                <field type="hidden" name="editevent_mail_category" default="0" />
                <field type="hidden" name="editevent_mail_category_acl" default="0" />
                <field type="hidden" name="editevent_mail_group" default="0" />
                <field type="hidden" name="newvenue_mail_user" default="1" />
                <field type="hidden" name="newvenue_mail_admin" default="1" />
                <field type="hidden" name="editvenue_mail_user" default="1" />
                <field type="hidden" name="editvenue_mail_creator" default="0" />
                <field type="hidden" name="editvenue_mail_ev-creator" default="0" />
                <field type="hidden" name="editvenue_mail_admin" default="1" />
                <field type="hidden" name="editvenue_mail_registered" default="0" />
                <field type="hidden" name="editvenue_mail_category" default="0" />
                <field type="hidden" name="editvenue_mail_group" default="0" />
                <field type="hidden" name="fetch_admin_mails" default="0" />
                <field type="hidden" name="admin_receivers" default="" />
                <field type="hidden" name="send_html" default="0" />
            </fieldset>
        </fields>
    </config>
</extension>




