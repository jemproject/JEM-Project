<?xml version="1.0" encoding="UTF-8"?>
<extension type="component" method="upgrade">
    <name>com_jem</name>
    <creationDate>21 July 2026</creationDate>
    <author>JEM Community</author>
    <copyright>copyright (C) 2013-2026 joomlaeventmanager.net</copyright>
    <license>https://www.gnu.org/licenses/gpl-3.0 GNU/GPL</license>
    <authorEmail>info@joomlaeventmanager.net</authorEmail>
    <authorUrl>https://www.joomlaeventmanager.net</authorUrl>
    <version>5.0.1beta1</version>
    <description>COM_JEM_INSTALLATION_XML_DESCRIPTION</description>
    <notes>Fixed duplicate JemHelper declarations that could cause fatal errors during upgrades. [Issue #2242](https://github.com/jemproject/JEM-Project/issues/2242);Updated Update Check to follow the Joomla administrator template colors. [Issue #2243](https://github.com/jemproject/JEM-Project/issues/2243);Restored upgrade support from JEM 4.4.x. [Issue #2247](https://github.com/jemproject/JEM-Project/issues/2247);Added validation for associated article title formats. [Issue #2248](https://github.com/jemproject/JEM-Project/issues/2248);Improved import security configuration and diagnostics. [Issue #2249](https://github.com/jemproject/JEM-Project/issues/2249);Expanded import and export workflows, profiles, venue data and map markers. [Issue #2250](https://github.com/jemproject/JEM-Project/issues/2250);Restored the hits column in the backend events list. [Issue #2251](https://github.com/jemproject/JEM-Project/issues/2251);Added attachment download statistics and event visit dates. [Issue #2252](https://github.com/jemproject/JEM-Project/issues/2252);Fixed Nominatim requests and isolated event and venue parameters. [Commit f199043](https://github.com/jemproject/JEM-Project/commit/f199043cd226d70f95b502d5778af4e3b20a3a16);Corrected the "Show my location" wording. [Commit 0a26eef](https://github.com/jemproject/JEM-Project/commit/0a26eef790b7f1b32007cc1da02752b0212ee10f)</notes>

    <scriptfile>script.php</scriptfile>

    <files folder="site">
        <filename>jem.php</filename>
        <filename>controller.php</filename>
        <filename>factory.php</filename>
        <filename>router.php</filename>
        <filename>index.html</filename>

        <folder>services</folder>
        <folder>classes</folder>
        <folder>common</folder>
        <folder>controllers</folder>
        <folder>helpers</folder>
        <folder>models</folder>
        <folder>views</folder>
        <folder>language</folder>
    </files>
    
    <media folder="media" destination="com_jem" target="media/com_jem">
        <filename>index.html</filename>
        <folder>images</folder>
        <folder>css</folder>
        <folder>js</folder>
        <folder>vendor</folder>
    </media>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <administration>
        <menu img="../media/com_jem/images/jem.webp" link="option=com_jem">COM_JEM</menu>

        <submenu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=main">COM_JEM_MENU_MAINMENU</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=events">COM_JEM_MENU_EVENTS</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=venues">COM_JEM_MENU_VENUES</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=categories">COM_JEM_MENU_CATEGORIES</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=types">COM_JEM_MENU_TYPES</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=specialdays">COM_JEM_MENU_SPECIAL_DAYS</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=groups">COM_JEM_MENU_GROUPS</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=attachments">COM_JEM_MENU_ATTACHMENTS</menu>
            <menu img="../media/com_jem/images/jem.webp" link="option=com_jem&amp;view=settings">COM_JEM_MENU_SETTINGS</menu>
        </submenu>

        <languages folder="admin/language">
            <language tag="en-GB">en-GB/com_jem.ini</language>
            <language tag="en-GB">en-GB/com_jem.sys.ini</language>
        </languages>

        <files folder="admin">
            <filename>jem.php</filename>
            <filename>controller.php</filename>
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <filename>index.html</filename>

            <folder>assets</folder>
            <folder>classes</folder>
            <folder>help</folder>
            <folder>helpers</folder>
            <folder>views</folder>
            <folder>models</folder>
            <folder>controllers</folder>
            <folder>sql</folder>
            <folder>tables</folder>
            <folder>language</folder>
        </files>
    </administration>

</extension>




