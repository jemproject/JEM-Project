                layout="joomla.form.field.subform.repeatable"
                multiple="true"
                label="COM_JEM_EVENT_LINKS"
                hiddenLabel="true"
                buttons="add,remove,move"
        >
            <form>
                <field name="id" type="hidden" />

                <field name="title" type="text"
                        label="COM_JEM_EVENT_LINK_TITLE"
                        class="form-control"
                />
                <field name="description" type="textarea"
                       label="COM_JEM_EVENT_LINK_DESCRIPTION"
                       rows="2"
                       filter="safehtml"
                       class="form-control"
                />
                <field name="type" type="jemlinktype"
                        label="COM_JEM_EVENT_LINK_TYPE"
                        default="info"
                >
                    <option value="info" data-icon="fa fa-info-circle">COM_JEM_EVENT_LINK_TXT_INFO</option>
                    <option value="online" data-icon="fa fa-globe">COM_JEM_EVENT_LINK_TXT_ONLINE</option>
                    <option value="request" data-icon="fa fa-ticket">COM_JEM_EVENT_LINK_TXT_REQUEST</option>
                    <option value="pay" data-icon="fa fa-credit-card">COM_JEM_EVENT_LINK_TXT_PAY</option>
                    <option value="price" data-icon="fa fa-tag">COM_JEM_EVENT_LINK_TXT_PRICE</option>
                    <option value="speaker" data-icon="fa fa-microphone">COM_JEM_EVENT_LINK_TXT_SPEAKER</option>
                    <option value="workshop" data-icon="fa fa-tools">COM_JEM_EVENT_LINK_TXT_WORKSHOP</option>
                    <option value="location" data-icon="fa fa-map-marker-alt">COM_JEM_EVENT_LINK_TXT_LOCATION</option>
                    <option value="calendar" data-icon="fa fa-calendar">COM_JEM_EVENT_LINK_TXT_CALENDAR</option>
                    <option value="document" data-icon="fa fa-file-alt">COM_JEM_EVENT_LINK_TXT_DOCUMENT</option>
                    <option value="sponsor" data-icon="fa fa-handshake">COM_JEM_EVENT_LINK_TXT_SPONSOR</option>
                    <option value="networking" data-icon="fa fa-users">COM_JEM_EVENT_LINK_TXT_NETWORKING</option>
                </field>
                <field name="color" type="color"
                        label="COM_JEM_EVENT_LINK_COLOR"
                        default="#2f6f46"
                />
                <field name="url" type="url"
                        label="COM_JEM_EVENT_LINK_URL"
                        filter="url"
                        class="form-control"
                />
                <field name="target" type="radio"
                        label="COM_JEM_EVENT_LINK_TARGET"
                        default="_blank"
                        class="btn-group btn-group-yesno"
                >
                    <option value="_blank">COM_JEM_EVENT_LINK_TARGET_NEW_TAB</option>
                    <option value="_self">COM_JEM_EVENT_LINK_TARGET_SAME_TAB</option>
                </field>
                <field name="frame" type="radio"
                        label="COM_JEM_EVENT_LINK_FRAME"
                        default="1"
                        class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="image" type="media"
                        label="COM_JEM_EVENT_LINK_IMAGE"
                />
                <field name="max_width" type="number"
                        label="COM_JEM_EVENT_LINK_MAX_IMAGE_WIDTH"
                        default="120"
                        min="0"
                        step="1"
                        class="form-control"
                />
                <field name="max_height" type="number"
                        label="COM_JEM_EVENT_LINK_MAX_IMAGE_HEIGHT"
                        default="60"
                        min="0"
                        step="1"
                        class="form-control"
                />

                <field name="icon" type="hidden" />
            </form>
        </field>
    </fieldset>

</form>
