<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="COM_JEM_CATEGORIES_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[COM_JEM_CATEGORIES_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="request">
        <fieldset name="request"
            addfieldpath="/administrator/components/com_jem/models/fields"
        >
            <field name="id" type="categories"
                default="1"
                label="COM_JEM_SELECTTOPCAT"
                description="COM_JEM_SELECTTOPCATDESC"
                required="false"
            />
            <field
                name="typeid"
                type="sql"
                label="COM_JEM_TYPE_FIELD_TYPE"
                description="COM_JEM_TYPE_FIELD_TYPE_DESC"
                query="SELECT 0 AS value, '- ' AS text UNION SELECT id AS value, name AS text FROM #__jem_types WHERE published = 1 AND entity = 2 ORDER BY text ASC"
                key_field="value"
                value_field="text"
                required="false"
            />
        </fieldset>
    </fields>

    <fields name="params">
        <fieldset name="basic">
            <field name="show_categories_filter" type="radio"
                default="1"
                label="COM_JEM_CATEGORIES_SHOW_FILTER"
                description="COM_JEM_CATEGORIES_SHOW_FILTER_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_categories_type_filter" type="radio"
                default="1"
                label="COM_JEM_CATEGORIES_SHOW_TYPE_FILTER"
                description="COM_JEM_CATEGORIES_SHOW_TYPE_FILTER_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_category_description" type="radio"
                default="1"
                label="COM_JEM_CATEGORIES_SHOW_DESCRIPTION"
                description="COM_JEM_CATEGORIES_SHOW_DESCRIPTION_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_category_type" type="radio"
                default="0"
                label="COM_JEM_CATEGORIES_SHOW_TYPE"
                description="COM_JEM_CATEGORIES_SHOW_TYPE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_category_image" type="radio"
                default="1"
                label="COM_JEM_CATEGORIES_SHOW_IMAGE"
                description="COM_JEM_CATEGORIES_SHOW_IMAGE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="show_category_events" type="radio"
                default="1"
                label="COM_JEM_CATEGORIES_SHOW_EVENTS"
                description="COM_JEM_CATEGORIES_SHOW_EVENTS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showemptycats" type="radio"
                default="1"
                label="COM_JEM_SHOWEMPTYCATS"
                description="COM_JEM_SHOWEMPTYCATSDESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="cat_num" type="text"
                size="2"
                default="4"
                label="COM_JEM_CAT_DISPLAY"
                description="COM_JEM_CAT_DISPLAY_DESC"
            />
            <field name="detcat_nr" type="text"
                size="1"
                default="3"
                label="COM_JEM_DET_CATEGORIES_PREVIEW"
                description="COM_JEM_DET_CATEGORIES_PREVIEW_DESC"
            />
            <field name="usecat" type="radio"
                default="1"
                label="COM_JEM_DISPLAYCHILDS"
                description="COM_JEM_DISPLAYCHILDSDESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="showemptychilds" type="radio"
                default="1"
                label="COM_JEM_SHOWEMPTYCHILD"
                description="COM_JEM_SHOWEMPTYCHILDDESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field type="spacer" name="page_text_spacer"
                label="COM_JEM_TIMELINE_BLOCK_PAGE_TEXT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_INTROTEXT"
                description="COM_JEM_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_INTROTEXT_FIELD"
                description="COM_JEM_INTROTEXT_FIELD_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_GLOBAL_FIELD_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_FOOTERTEXT_DESC"
            /></fieldset>
    </fields>
</metadata>
