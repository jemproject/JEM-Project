<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="COM_JEM_ANNUALCALENDAR_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[COM_JEM_ANNUALCALENDAR_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="params">
        <fieldset name="basic" addfieldpath="/administrator/components/com_jem/models/fields">
            <field name="annual_start_month" type="list"
                default="1"
                label="COM_JEM_ANNUALCALENDAR_START_MONTH"
                description="COM_JEM_ANNUALCALENDAR_START_MONTH_DESC" class="form-select w-auto jem-options-width-auto"
            >
                <option value="1">JANUARY</option>
                <option value="2">FEBRUARY</option>
                <option value="3">MARCH</option>
                <option value="4">APRIL</option>
                <option value="5">MAY</option>
                <option value="6">JUNE</option>
                <option value="7">JULY</option>
                <option value="8">AUGUST</option>
                <option value="9">SEPTEMBER</option>
                <option value="10">OCTOBER</option>
                <option value="11">NOVEMBER</option>
                <option value="12">DECEMBER</option>
            </field>
            <field name="annual_marker_limit" type="number"
                default="6"
                min="1"
                max="12"
                label="COM_JEM_ANNUALCALENDAR_MARKER_LIMIT"
                description="COM_JEM_ANNUALCALENDAR_MARKER_LIMIT_DESC" class="form-control w-auto"
            />
            <field name="annual_show_day_event_count" type="radio"
                default="0"
                label="COM_JEM_ANNUALCALENDAR_SHOW_DAY_EVENT_COUNT"
                description="COM_JEM_ANNUALCALENDAR_SHOW_DAY_EVENT_COUNT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="annual_day_link_target" type="list"
                default="default"
                label="COM_JEM_ANNUALCALENDAR_DAY_LINK_TARGET"
                description="COM_JEM_ANNUALCALENDAR_DAY_LINK_TARGET_DESC"
                class="form-select w-auto jem-options-width-auto"
            >
                <option value="default">COM_JEM_ANNUALCALENDAR_DAY_LINK_TARGET_DAY</option>
                <option value="timetable">COM_JEM_DAY_VIEW_TIMETABLE_TITLE</option>
                <option value="timeline">COM_JEM_DAY_VIEW_TIMELINE_TITLE</option>
            </field>
            <field name="show_types_of_days_legend" type="radio"
                default="1"
                label="COM_JEM_CALENDAR_SHOW_TYPES_OF_DAYS_LEGEND"
                description="COM_JEM_CALENDAR_SHOW_TYPES_OF_DAYS_LEGEND_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="special_day_legend_order" type="list"
                default="order_asc"
                label="COM_JEM_CALENDAR_TYPES_OF_DAYS_LEGEND_ORDER"
                description="COM_JEM_CALENDAR_TYPES_OF_DAYS_LEGEND_ORDER_DESC"
                class="form-select w-auto jem-options-width-auto"
            >
                <option value="id_asc">COM_JEM_ORDER_ID_ASC</option>
                <option value="id_desc">COM_JEM_ORDER_ID_DESC</option>
                <option value="order_asc">COM_JEM_ORDER_ORDER_ASC</option>
                <option value="order_desc">COM_JEM_ORDER_ORDER_DESC</option>
                <option value="name_asc">COM_JEM_ORDER_NAME_ASC</option>
                <option value="name_desc">COM_JEM_ORDER_NAME_DESC</option>
                <option value="start_date">COM_JEM_ORDER_START_DATE</option>
                <option value="end_date">COM_JEM_ORDER_END_DATE</option>
            </field>
            <field name="annual_agenda_show_empty_days" type="radio"
                default="0"
                label="COM_JEM_ANNUALCALENDAR_AGENDA_SHOW_EMPTY_DAYS"
                description="COM_JEM_ANNUALCALENDAR_AGENDA_SHOW_EMPTY_DAYS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="annual_agenda_show_empty_months" type="radio"
                default="1"
                label="COM_JEM_ANNUALCALENDAR_AGENDA_SHOW_EMPTY_MONTHS"
                description="COM_JEM_ANNUALCALENDAR_AGENDA_SHOW_EMPTY_MONTHS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="onlyfeatured" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_FEATUREDONLY"
                description="COM_JEM_DISPLAY_FEATUREDONLY_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="categoryswitch" type="radio"
                default="0"
                label="COM_JEM_TIMELINE_CATEGORY_FILTER_MODE_LABEL"
                description="COM_JEM_CATEGORYSWITCH_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">COM_JEM_INCLUDE</option>
                <option value="0">COM_JEM_EXCLUDE</option>
            </field>
            <field name="categoryswitchcats" type="categoryedit"
                multiple="true"
                removeroot="true"
                class="form-select w-auto jem-options-width-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_CATEGORIES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_CATEGORIES_DESC"
            />
            <field name="timeline_filter_venues" type="venueoptions"
                multiple="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_VENUES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_VENUES_DESC"
            />
            <field name="timeline_filter_types" type="jemtype"
                entity="1"
                multiple="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_TYPES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_TYPES_DESC"
            />
            <field name="timeline_filter_countries" type="countryoptions"
                multiple="true"
                class="form-select w-auto jem-options-width-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_COUNTRIES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_COUNTRIES_DESC"
            />
            <field name="top_category" type="categories"
                default="0"
                label="COM_JEM_SELECT_TOP_CATEGORY"
                description="COM_JEM_SELECT_TOP_CATEGORY_DESC" class="form-select w-auto"
            />
            <field name="show_archived_events" type="radio"
                default="0"
                label="COM_JEM_SHOW_ARCHIVED_EVENTS"
                description="COM_JEM_SHOW_ARCHIVED_EVENTS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="displayLegend" type="list"
                default="1"
                label="COM_JEM_DISPLAY_LEGEND"
                description="COM_JEM_DISPLAY_LEGEND_DESC" class="form-select w-auto jem-options-width-auto"
            >
                <option value="0">JNO</option>
                <option value="1">COM_JEM_BELOW</option>
                <option value="2">COM_JEM_ABOVE</option>
                <option value="3">COM_JEM_BELOW_WITH_VENUES</option>
                <option value="4">COM_JEM_ABOVE_WITH_VENUES</option>
                <option value="5">COM_JEM_BELOW_ONLY_VENUES</option>
                <option value="6">COM_JEM_ABOVE_ONLY_VENUES</option>
            </field>
            <field name="show_only_start" type="radio"
                default="0"
                label="COM_JEM_SHOWONLYSTARTDAY"
                description="COM_JEM_SHOWONLYSTARTDAY_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="firstweekday" type="list"
                default="1"
                label="COM_JEM_SELECTFIRSTWEEKDAY"
                description="COM_JEM_SELECTFIRSTWEEKDAYDESC" class="form-select w-auto jem-options-width-auto"
            >
                <option value="0">COM_JEM_SUNDAY</option>
                <option value="1">COM_JEM_MONDAY</option>
            </field>
            <field name="show_addevent_icon" type="radio"
                default="0"
                label="COM_JEM_SHOWADDEVENTICON"
                description="COM_JEM_SHOWADDEVENTICON_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="categoryColorMarker" type="radio"
                default="0"
                label="COM_JEM_CALENDAR_CATEGORY_COLOR_MARKER"
                description="COM_JEM_CALENDAR_CATEGORY_COLOR_MARKER_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="0">COM_JEM_MARKER_BLOCK</option>
                <option value="1">COM_JEM_MARKER_TOP_BAR</option>
            </field>
            <field name="eventbg_usecatcolor" type="radio"
                default="0"
                label="COM_JEM_CALENDAR_USECATCOLOR"
                description="COM_JEM_CALENDAR_USECATCOLOR_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="currentdaycolor" type="color"
                default="#CCCC99"
                label="COM_JEM_CALENDAR_CURRENTDAYCOLOR"
                description="COM_JEM_CALENDAR_CURRENTDAYCOLOR_DESC"
                class="form-control-color w-auto"
            />
            <field type="spacer" name="page_text_spacer"
                label="COM_JEM_TIMELINE_BLOCK_PAGE_TEXT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_INTROTEXT"
                description="COM_JEM_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_INTROTEXT_FIELD"
                description="COM_JEM_INTROTEXT_FIELD_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_GLOBAL_FIELD_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_FOOTERTEXT_DESC"
            />
        </fieldset>
    </fields>
</metadata>
