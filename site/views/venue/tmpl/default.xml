<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="COM_JEM_VENUE_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[COM_JEM_VENUE_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="request">
        <fieldset name="request"
            addfieldpath="/administrator/components/com_jem/models/fields"
        >
            <field name="id" type="modal_venue"
                label="COM_JEM_SELECTVENUE"
                description="COM_JEM_SELECTVENUE_DESC"
                required="true"
            />
        </fieldset>
    </fields>


    <fields name="params">
        <fieldset name="basic">
            <field type="spacer" name="page_text_spacer"
                label="COM_JEM_TIMELINE_BLOCK_PAGE_TEXT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_INTROTEXT"
                description="COM_JEM_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_INTROTEXT_FIELD"
                description="COM_JEM_INTROTEXT_FIELD_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_GLOBAL_FIELD_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_FOOTERTEXT_DESC"
            />
            <field type="spacer" name="venue_details_spacer"
                label="COM_JEM_VENUE_DETAILS_OPTIONS"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="venue_show_status" type="radio"
                default="1"
                label="COM_JEM_VENUE_SHOW_STATUS"
                description="COM_JEM_VENUE_SHOW_STATUS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="venue_map_display" type="list"
                default="global"
                label="COM_JEM_VENUE_MAP_DISPLAY"
                description="COM_JEM_VENUE_MAP_DISPLAY_DESC"
            >
                <option value="global">COM_JEM_USE_GLOBAL</option>
                <option value="hide">COM_JEM_HIDE</option>
                <option value="link">COM_JEM_MAP_LINK</option>
                <option value="map">COM_JEM_EMBEDDED_MAP</option>
            </field>
        </fieldset>
    </fields>
</metadata>
