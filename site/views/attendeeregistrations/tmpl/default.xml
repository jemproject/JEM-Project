<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="COM_JEM_ATTENDEE_REGISTRATIONS_VIEW_DEFAULT_TITLE">
        <message>
            <![CDATA[COM_JEM_ATTENDEE_REGISTRATIONS_VIEW_DEFAULT_DESC]]>
        </message>
    </layout>

    <fields name="params">
        <fieldset name="columns" label="COM_JEM_MYATTENDANCES_FIELDSET_COLUMNS">
            <field name="registration_columns" type="list"
                default="registration_id,name,username,places,uregdate,event,event_date,status"
                label="COM_JEM_ATTENDEE_REGISTRATIONS_COLUMNS"
                description="COM_JEM_ATTENDEE_REGISTRATIONS_COLUMNS_DESC"
                multiple="true"
                size="12"
                class="form-select"
            >
                <option value="registration_id">COM_JEM_ATTENDEES_REGID</option>
                <option value="name">COM_JEM_NAME</option>
                <option value="username">COM_JEM_USERNAME</option>
                <option value="user_id">COM_JEM_USER_ID</option>
                <option value="email">COM_JEM_EMAIL</option>
                <option value="places">COM_JEM_TABLE_PLACES</option>
                <option value="uregdate">COM_JEM_ATTENDEE_REGISTRATION_DATE</option>
                <option value="event">COM_JEM_EVENT</option>
                <option value="event_date">COM_JEM_ATTENDEE_EVENT_DATE</option>
                <option value="venue">COM_JEM_VENUE</option>
                <option value="status">COM_JEM_STATUS</option>
                <option value="comment">COM_JEM_COMMENT</option>
            </field>
        </fieldset>
        <fieldset name="basic">
            <field type="spacer" name="page_text_spacer"
                label="COM_JEM_TIMELINE_BLOCK_PAGE_TEXT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_INTROTEXT"
                description="COM_JEM_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_INTROTEXT_FIELD"
                description="COM_JEM_INTROTEXT_FIELD_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_GLOBAL_FIELD_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_FOOTERTEXT_DESC"
            />
        </fieldset>
    </fields>
</metadata>
