<?xml version="1.0" encoding="UTF-8"?>
<metadata>
    <layout title="COM_JEM_DAY_VIEW_TIMELINE_TITLE">
        <message>
            <![CDATA[COM_JEM_DAY_VIEW_TIMELINE_DESC]]>
        </message>
    </layout>

    <fields name="params">
        <fieldset name="basic" addfieldpath="/administrator/components/com_jem/models/fields">
            <field type="spacer" name="timeline_date_range_spacer"
                label="COM_JEM_TIMELINE_BLOCK_DATE_RANGE"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="days" type="text"
                default="0"
                size="2"
                class="inputbox form-control w-auto"
                label="COM_JEM_DAYS_FIELD"
                description="COM_JEM_DAYS_FIELD_DESC"
            />
            <field name="timeline_days_to_show" type="number"
                default="1"
                min="1"
                max="60"
                step="1"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMELINE_DAYS_TO_SHOW_LABEL"
                description="COM_JEM_TIMELINE_DAYS_TO_SHOW_DESC"
            />
            <field name="timeline_show_empty_days" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_SHOW_EMPTY_DAYS_LABEL"
                description="COM_JEM_TIMELINE_SHOW_EMPTY_DAYS_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timetable_hour_display" type="list"
                default="event_hours"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMETABLE_HOUR_DISPLAY"
                description="COM_JEM_TIMETABLE_HOUR_DISPLAY_DESC"
            >
                <option value="event_hours">COM_JEM_TIMETABLE_HOUR_DISPLAY_EVENT_HOURS</option>
                <option value="all_hours">COM_JEM_TIMETABLE_HOUR_DISPLAY_ALL_HOURS</option>
            </field>
            <field name="timetable_range_start" type="text"
                default="08:00"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMETABLE_RANGE_START"
                description="COM_JEM_TIMETABLE_RANGE_START_DESC"
            />
            <field name="timetable_range_end" type="text"
                default="22:00"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMETABLE_RANGE_END"
                description="COM_JEM_TIMETABLE_RANGE_END_DESC"
            />
            <field name="timetable_grid_interval" type="number"
                default="60"
                min="5"
                max="240"
                step="5"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMETABLE_GRID_INTERVAL"
                description="COM_JEM_TIMETABLE_GRID_INTERVAL_DESC"
            />
            <field name="timetable_grid_subinterval" type="number"
                default="15"
                min="0"
                max="120"
                step="5"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMETABLE_GRID_SUBINTERVAL"
                description="COM_JEM_TIMETABLE_GRID_SUBINTERVAL_DESC"
            />
            <field type="spacer" name="timeline_layout_spacer"
                label="COM_JEM_TIMELINE_BLOCK_LAYOUT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="timeline_side" type="list"
                default="right"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMELINE_SIDE_LABEL"
                description="COM_JEM_TIMELINE_SIDE_DESC"
            >
                <option value="right">COM_JEM_TIMELINE_SIDE_RIGHT</option>
                <option value="left">COM_JEM_TIMELINE_SIDE_LEFT</option>
                <option value="alternate">COM_JEM_TIMELINE_SIDE_ALTERNATE</option>
            </field>
            <field name="timeline_right_text_align" type="list"
                default="left"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMELINE_RIGHT_TEXT_ALIGN_LABEL"
                description="COM_JEM_TIMELINE_RIGHT_TEXT_ALIGN_DESC"
            >
                <option value="left">JGLOBAL_LEFT</option>
                <option value="center">JGLOBAL_CENTER</option>
                <option value="right">JGLOBAL_RIGHT</option>
            </field>
            <field name="timeline_left_text_align" type="list"
                default="right"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMELINE_LEFT_TEXT_ALIGN_LABEL"
                description="COM_JEM_TIMELINE_LEFT_TEXT_ALIGN_DESC"
            >
                <option value="left">JGLOBAL_LEFT</option>
                <option value="center">JGLOBAL_CENTER</option>
                <option value="right">JGLOBAL_RIGHT</option>
            </field>
            <field name="timeline_width" type="number"
                default="80"
                min="40"
                max="100"
                step="5"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMELINE_WIDTH_LABEL"
                description="COM_JEM_TIMELINE_WIDTH_DESC"
            />
            <field name="timeline_line_color" type="color"
                default="#6c757d"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMELINE_LINE_COLOR_LABEL"
                description="COM_JEM_TIMELINE_LINE_COLOR_DESC"
            />
            <field name="timeline_line_style" type="list"
                default="solid"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMELINE_LINE_STYLE_LABEL"
                description="COM_JEM_TIMELINE_LINE_STYLE_DESC"
            >
                <option value="solid">COM_JEM_TIMELINE_LINE_STYLE_SOLID</option>
                <option value="dotted">COM_JEM_TIMELINE_LINE_STYLE_DOTTED</option>
                <option value="dashed">COM_JEM_TIMELINE_LINE_STYLE_DASHED</option>
                <option value="double">COM_JEM_TIMELINE_LINE_STYLE_DOUBLE</option>
                <option value="groove">COM_JEM_TIMELINE_LINE_STYLE_GROOVE</option>
                <option value="ridge">COM_JEM_TIMELINE_LINE_STYLE_RIDGE</option>
            </field>
            <field name="timeline_event_frame" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_EVENT_FRAME_LABEL"
                description="COM_JEM_TIMELINE_EVENT_FRAME_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timetable_event_background" type="list"
                default="category"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMETABLE_EVENT_BACKGROUND"
                description="COM_JEM_TIMETABLE_EVENT_BACKGROUND_DESC"
            >
                <option value="category">COM_JEM_TIMETABLE_EVENT_BACKGROUND_CATEGORY</option>
                <option value="venue">COM_JEM_TIMETABLE_EVENT_BACKGROUND_VENUE</option>
                <option value="custom">COM_JEM_TIMETABLE_EVENT_BACKGROUND_CUSTOM</option>
            </field>
            <field name="timeline_event_color_mode" type="list"
                default="bar"
                class="inputbox form-select w-auto"
                label="COM_JEM_TIMELINE_EVENT_COLOR_MODE_LABEL"
                description="COM_JEM_TIMELINE_EVENT_COLOR_MODE_DESC"
            >
                <option value="bar">COM_JEM_TIMELINE_EVENT_COLOR_MODE_BAR</option>
                <option value="background">COM_JEM_TIMELINE_EVENT_COLOR_MODE_BACKGROUND</option>
            </field>
            <field name="timetable_event_background_custom" type="color"
                default="#6bbf59"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMETABLE_EVENT_BACKGROUND_CUSTOM_COLOR"
                description="COM_JEM_TIMETABLE_EVENT_BACKGROUND_CUSTOM_COLOR_DESC"
            />
            <field type="spacer" name="timeline_content_spacer"
                label="COM_JEM_TIMELINE_BLOCK_EVENT_CONTENT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="timeline_show_category" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_SHOW_CATEGORY_LABEL"
                description="COM_JEM_TIMELINE_SHOW_CATEGORY_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timeline_show_venue" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_SHOW_VENUE_LABEL"
                description="COM_JEM_TIMELINE_SHOW_VENUE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timeline_show_type" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_SHOW_TYPE_LABEL"
                description="COM_JEM_TIMELINE_SHOW_TYPE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timeline_show_event_intro" type="radio"
                default="0"
                label="COM_JEM_TIMELINE_SHOW_EVENT_INTRO_LABEL"
                description="COM_JEM_TIMELINE_SHOW_EVENT_INTRO_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timeline_event_intro_limit" type="number"
                default="160"
                min="0"
                max="1000"
                step="10"
                class="inputbox form-control w-auto"
                label="COM_JEM_TIMELINE_EVENT_INTRO_LIMIT_LABEL"
                description="COM_JEM_TIMELINE_EVENT_INTRO_LIMIT_DESC"
            />
            <field name="timeline_show_event_image" type="radio"
                default="1"
                label="COM_JEM_TIMELINE_SHOW_EVENT_IMAGE_LABEL"
                description="COM_JEM_TIMELINE_SHOW_EVENT_IMAGE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="timeline_show_venue_image" type="radio"
                default="0"
                label="COM_JEM_TIMELINE_SHOW_VENUE_IMAGE_LABEL"
                description="COM_JEM_TIMELINE_SHOW_VENUE_IMAGE_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field type="spacer" name="timeline_filtering_spacer"
                label="COM_JEM_TIMELINE_BLOCK_FILTERING"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="onlyfeatured" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_FEATUREDONLY"
                description="COM_JEM_DISPLAY_FEATUREDONLY_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="categoryswitch" type="radio"
                default="0"
                label="COM_JEM_TIMELINE_CATEGORY_FILTER_MODE_LABEL"
                description="COM_JEM_CATEGORYSWITCH_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">COM_JEM_INCLUDE</option>
                <option value="0">COM_JEM_EXCLUDE</option>
            </field>
            <field name="categoryswitchcats" type="categoryedit"
                multiple="true"
                removeroot="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_CATEGORIES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_CATEGORIES_DESC"
            />
            <field name="timeline_filter_venues" type="venueoptions"
                multiple="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_VENUES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_VENUES_DESC"
            />
            <field name="timeline_filter_types" type="jemtype"
                entity="1"
                multiple="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_TYPES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_TYPES_DESC"
            />
            <field name="timeline_filter_countries" type="countryoptions"
                multiple="true"
                class="form-select w-auto"
                default=""
                label="COM_JEM_TIMELINE_FILTER_COUNTRIES_LABEL"
                description="COM_JEM_TIMELINE_FILTER_COUNTRIES_DESC"
            />
            <field type="spacer" name="page_text_spacer"
                label="COM_JEM_TIMELINE_BLOCK_PAGE_TEXT"
                class="badge border px-3 py-2 fs-5 fw-bold text-body"
            />
            <field name="showintrotext" type="radio"
                default="0"
                label="COM_JEM_DISPLAY_INTROTEXT"
                description="COM_JEM_DISPLAY_INTROTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="introtext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_INTROTEXT_FIELD"
                description="COM_JEM_INTROTEXT_FIELD_DESC"
            />
            <field name="showfootertext" type="radio"
                default="0"
                label="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_SHOW_FOOTERTEXT_DESC"
                class="btn-group btn-group-yesno"
            >
                <option value="1">JYES</option>
                <option value="0">JNO</option>
            </field>
            <field name="footertext" type="editor"
                filter="safehtml"
                hide="readmore,pagebreak,module,menu,fields,contact,article"
                default=""
                rows="8"
                cols="30"
                height="300px"
                label="COM_JEM_GLOBAL_FIELD_FOOTERTEXT"
                description="COM_JEM_GLOBAL_FIELD_FOOTERTEXT_DESC"
            /></fieldset>
    </fields>
</metadata>
